# Wikidata Configuration
CONTACT_EMAIL=your-email@example.com
WIKIDATA_SPARQL_URL=https://query.wikidata.org/sparql

# Proxy Configuration (comma-separated)
PROXY_LIST=

# Cache Configuration
CACHE_TTL_SECONDS=300
CACHE_MAX_SIZE=10000

# Performance Configuration
SPARQL_TIMEOUT_SECONDS=60
STREAMING_PAGE_SIZE=50
MAX_WORKERS=3

# Debug Configuration
DEBUG_QUERIES=false  # Set to "true", "1", or "yes" to write SPARQL queries to files

# Server Configuration
UVICORN_HOST=0.0.0.0
UVICORN_PORT=8000
UVICORN_WORKERS=2
